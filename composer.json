{
    "name": "nickhblair/bazaar",
    "description": "A WordPress plugin that turns wp-admin into an app marketplace for .wp ware packages.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "automattic/vipwpcs": "^3.0",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpstan/extension-installer": "^1.4",
        "brain/monkey": "^2.6",
        "phpunit/phpunit": "^10.5",
        "php-stubs/wordpress-stubs": "^6.6"
    },
    "autoload": {
        "psr-4": {
            "Bazaar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bazaar\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": [
            "@phpcs",
            "@phpstan"
        ],
        "phpcs": "phpcs --standard=phpcs.xml",
        "phpstan": "phpstan analyse --memory-limit=256M",
        "format": "phpcbf --standard=phpcs.xml",
        "test": "phpunit --configuration=phpunit.xml"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable"
}

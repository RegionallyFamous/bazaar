{
  "name": "tome",
  "version": "1.0.0",
  "description": "A fast internal wiki for your team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":     "vite",
    "build":   "tsc -b && vite build",
    "preview": "vite preview",
    "package": "npm run build && cp manifest.json dist/ && cd dist && zip -r ../../tome.wp . && echo 'Packaged: tome.wp'"
  },
  "dependencies": {
    "@bazaar/client": "^0.1.0",
    "@bazaar/design":  "^0.1.0",
    "dompurify":       "^3.2.5",
    "marked":          "^15.0.12",
    "react":           "^19.0.0",
    "react-dom":       "^19.0.0"
  },
  "devDependencies": {
    "@types/dompurify":     "^3.0.5",
    "@types/marked":        "^5.0.2",
    "@types/react":         "^19.0.0",
    "@types/react-dom":     "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript":           "^5.7.0",
    "vite":                 "^6.0.0"
  }
}

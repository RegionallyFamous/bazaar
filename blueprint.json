{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/admin.php?page=bazaar",
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://regionallyfamous.github.io/bazaar/bazaar.zip"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp plugin activate bazaar"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/board.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/flow.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/ledger.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/mosaic.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/sine.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/swatch.wp --force"
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install https://regionallyfamous.github.io/bazaar/tome.wp --force"
    }
  ]
}

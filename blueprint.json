{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/admin.php?page=bazaar",
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://regionallyfamous.github.io/bazaar/bazaar.zip"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp plugin activate bazaar"
    },
    {
      "step": "writeFile",
      "path": "/tmp/board.wp",
      "data": {
        "resource": "url",
        "url": "https://regionallyfamous.github.io/bazaar/board.wp"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install /tmp/board.wp --force"
    },
    {
      "step": "writeFile",
      "path": "/tmp/flow.wp",
      "data": {
        "resource": "url",
        "url": "https://regionallyfamous.github.io/bazaar/flow.wp"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp bazaar install /tmp/flow.wp --force"
    },

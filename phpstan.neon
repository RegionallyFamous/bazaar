parameters:
    level: 8
    paths:
        - bazaar.php
        - src/
    bootstrapFiles:
        - vendor/szepeviktor/phpstan-wordpress/bootstrap.php
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        - vendor/php-stubs/wp-cli-stubs/wp-cli-i18n-stubs.php
        - bazaar.php
    treatPhpDocTypesAsCertain: false
    # The phpstan-wordpress bootstrap sets ABSPATH='/' which makes
    # require_once ABSPATH.'wp-admin/includes/file.php' appear to reference a
    # non-existent path on macOS. The file is always present in real WordPress
    # installs. reportUnmatchedIgnoredErrors: false prevents CI from failing
    # when the same pattern doesn't trigger on Linux runners.
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - message: '#Path in require_once\(\) .* is not a file or it does not exist#'
          path: src/
    # Run single-process in CI so all memory stays in one PHP process.
    # PHPStan's parallel workers each inherit the PHP memory_limit; with the
    # heavyweight WordPress stubs this tips the total well over 512 MB.
    parallel:
        maximumNumberOfProcesses: 1

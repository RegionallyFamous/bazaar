{
	"name": "bazaar",
	"version": "1.3.3",
	"description": "Bazaar WordPress Plugin admin UI",
	"private": true,
	"workspaces": [
		"packages/*",
		"wares/*"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"lint": "npm run lint:js && npm run lint:css",
		"lint:js": "wp-scripts lint-js admin/src/",
		"lint:css": "wp-scripts lint-style 'admin/src/*.css'",
		"format": "wp-scripts format admin/src/",
		"test": "wp-scripts test-unit-js --config jest.config.js",
		"typecheck": "npm run -w packages/design typecheck && npm run -w packages/client typecheck && npm run -w wares/flow typecheck && npm run -w wares/mosaic typecheck && npm run -w wares/tome typecheck && npm run -w wares/ledger typecheck && npm run -w wares/board typecheck && npm run -w wares/swatch typecheck && npm run -w wares/sine typecheck",
		"prepare": "husky || :",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.43.0",
		"@wordpress/i18n": "^6.16.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@wordpress/env": "^11.3.0",
		"@wordpress/eslint-plugin": "^24.5.0",
		"@wordpress/scripts": "^31.8.0",
		"@wordpress/stylelint-config": "^23.35.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"vite": "^8.0.8"
	},
	"overrides": {
		"minimatch": "^10.2.5",
		"serialize-javascript": "^7.0.5",
		"webpack-dev-server": "^5.2.3"
	},
	"lint-staged": {
		"admin/src/**/*.js": [
			"wp-scripts lint-js"
		],
		"admin/src/**/*.css": [
			"wp-scripts lint-style"
		],
		"**/*.php": [
			"composer phpcs"
		]
	},
	"eslintConfig": {
		"extends": [
			"plugin:@wordpress/eslint-plugin/recommended"
		],
		"env": {
			"browser": true,
			"es2022": true
		},
		"rules": {
			"no-console": [
				"error",
				{
					"allow": [
						"error"
					]
				}
			],
			"camelcase": [
				"error",
				{
					"allow": [
						"unstable_useCacheRefresh",
						"duration_ms"
					]
				}
			]
		},
		"overrides": [
			{
				"files": [
					"tests/**/*.js",
					"tests/**/*.ts"
				],
				"rules": {
					"no-console": "off"
				}
			}
		]
	},
	"stylelint": {
		"extends": [
			"@wordpress/stylelint-config"
		],
		"rules": {
			"selector-class-pattern": [
				"^([a-z][a-z0-9]*)(-[a-z0-9]+)*(__[a-z][a-z0-9]*(-[a-z0-9]+)*)?(--[a-z][a-z0-9]*(-[a-z0-9]+)*)?$",
				{
					"message": "Selector should use lowercase BEM naming (block__element--modifier)"
				}
			]
		}
	}
}

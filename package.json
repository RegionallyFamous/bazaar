{
  "name": "bazaar",
  "version": "1.0.2",
  "description": "Bazaar WordPress Plugin admin UI",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "wp-scripts lint-js admin/src/",
    "lint:css": "wp-scripts lint-style 'admin/src/*.css'",
    "format": "wp-scripts format admin/src/",
    "test": "wp-scripts test-unit-js --config jest.config.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.43.0",
    "@wordpress/i18n": "^6.16.0"
  },
  "devDependencies": {
    "@wordpress/eslint-plugin": "^24.5.0",
    "@wordpress/scripts": "^31.8.0",
    "@wordpress/stylelint-config": "^23.35.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite": "^8.0.8"
  },
  "overrides": {
    "minimatch": "^10.2.5",
    "serialize-javascript": "^7.0.5",
    "webpack-dev-server": "^5.2.3"
  },
  "lint-staged": {
    "admin/src/**/*.js": [
      "wp-scripts lint-js"
    ],
    "admin/src/**/*.css": [
      "wp-scripts lint-style"
    ],
    "**/*.php": [
      "composer phpcs"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:@wordpress/eslint-plugin/recommended"
    ],
    "env": {
      "browser": true,
      "es2022": true
    }
  },
  "stylelint": {
    "extends": [
      "@wordpress/stylelint-config"
    ],
    "rules": {
      "selector-class-pattern": [
        "^([a-z][a-z0-9]*)(-[a-z0-9]+)*(__[a-z][a-z0-9]*(-[a-z0-9]+)*)?(--[a-z][a-z0-9]*(-[a-z0-9]+)*)?$",
        {
          "message": "Selector should use lowercase BEM naming (block__element--modifier)"
        }
      ]
    }
  }
}
